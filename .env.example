# Environment
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CORS - add your frontend URL
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Upload settings
UPLOAD_DIR=./uploads
CHUNK_DIR=./uploads/chunks
MAX_FILE_SIZE=5368709120
CHUNK_SIZE=5242880

# Exercise detection
MOTION_BUFFER_SIZE=60
CONFIDENCE_THRESHOLD=0.80
EXERCISE_SWITCH_DELAY=2.0

# Supabase (disabled for MVP)
SUPABASE_ENABLED=False
